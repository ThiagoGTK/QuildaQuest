# Credenciais da API do Telegram (https://my.telegram.org/apps)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Gerada uma única vez rodando `npm run login` — NUNCA versionar o valor real
TELEGRAM_SESSION=

# ID numérico do grupo da guilda (negativo, ex: -1001234567890)
TELEGRAM_GROUP_ID=

# Nome de usuário do bot cujos cards de combate devem ser contados (sem @)
TELEGRAM_SOURCE_BOT_USERNAME=Teletofus

# Supabase (Project Settings > API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
