# Token do bot, gerado pelo @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=

# ID numérico do grupo da guilda (negativo, ex: -1001234567890)
TELEGRAM_GROUP_ID=

# ID do seu chat privado com o bot — é para onde as notificações de abate são enviadas
TELEGRAM_OWNER_CHAT_ID=

# Nome de usuário do bot cujos cards de combate devem ser contados (sem @)
TELEGRAM_SOURCE_BOT_USERNAME=Teletofus

# Supabase (Project Settings > API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
